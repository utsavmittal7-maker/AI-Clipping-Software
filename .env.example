# Gemini API Key
GEMINI_API_KEY="YOUR_API_KEY_HERE"

# Output directory for generated clips
OUTPUT_DIR="./clips"

# Temporary directory for intermediate files
TEMP_DIR="./temp"

# Whisper model size
WHISPER_MODEL="large-v2"

# Custom user agent for YouTube requests (optional)
# YOUTUBE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"

# Note: This application now uses pytube instead of yt-dlp for YouTube downloads
# which should provide a more reliable download experience

# ---------------------------------------------------------------------------
# Editing features (all optional - sensible defaults are used if omitted)
# ---------------------------------------------------------------------------

# Auto-cleanup: remove filler words ("um", "uh") and long silences (true/false)
AUTO_CLEANUP="true"
# SILENCE_GAP: a pause longer than this many seconds gets trimmed
SILENCE_GAP="0.6"

# Review clips: pause to let you trim/drop clips before rendering (true/false)
REVIEW_CLIPS="false"

# Save a cover image (.jpg) for each clip (true/false)
GENERATE_THUMBNAILS="true"
# Save a short AI summary of the whole video (true/false)
GENERATE_SUMMARY="true"

# --- Branding & music (leave blank to disable; give a full path to enable) ---
# Background music mixed under each clip, e.g. C:\Users\you\Music\bg.mp3
MUSIC_PATH=""
MUSIC_VOLUME="0.12"
# Logo / watermark PNG (transparent background recommended), shown top-center
LOGO_PATH=""
# Optional intro / outro clips added before / after each generated clip
INTRO_PATH=""
OUTRO_PATH=""
